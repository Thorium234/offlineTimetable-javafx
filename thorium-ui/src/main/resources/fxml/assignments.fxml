<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.thorium.ui.controller.AssignmentManagementController" spacing="0"
      styleClass="view-root">
    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="page-header">
        <Label text="Assignments" styleClass="page-title"/>
        <Label text="Assign teachers to subjects and class streams" styleClass="page-subtitle"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="view-scroll">
        <VBox spacing="16" styleClass="view-content">

            <Label fx:id="messageLabel" styleClass="msg-label" managed="false"/>

            <!-- STEP 1: Teacher Cards -->
            <VBox spacing="0" styleClass="card" fx:id="stepTeachers">
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="card-header">
                    <Label text="Select Teacher" styleClass="card-title"/>
                    <Label text="Choose a teacher to manage their subjects and streams" styleClass="card-subtitle"/>
                </HBox>
                <VBox spacing="12" styleClass="card-body">
                    <FlowPane fx:id="teacherCardContainer" hgap="16" vgap="16"/>
                </VBox>
            </VBox>

            <!-- STEP 2: Subject Toggles -->
            <VBox spacing="0" styleClass="card" fx:id="stepSubjects" visible="false" managed="false">
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="card-header">
                    <Button fx:id="backToTeachersBtn" text="&lt; Teachers" onAction="#onBackToTeachers" styleClass="btn-back"/>
                    <Label fx:id="selectedTeacherLabel" text="Subjects for:" styleClass="card-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="continueToStreamsBtn" text="Continue to Streams →" onAction="#onContinueToStreams" styleClass="btn-primary"/>
                </HBox>
                <VBox spacing="12" styleClass="card-body">
                    <Label text="Toggle subjects to assign or unassign (saves automatically)" styleClass="hint-text"/>
                    <FlowPane fx:id="subjectToggleContainer" hgap="12" vgap="12"/>
                </VBox>
            </VBox>

            <!-- STEP 3: Subject Cards for Stream Assignment -->
            <VBox spacing="0" styleClass="card" fx:id="stepStreamSubjects" visible="false" managed="false">
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="card-header">
                    <Button text="&lt; Subjects" onAction="#onBackToSubjects" styleClass="btn-back"/>
                    <Label fx:id="streamSubjectTeacherLabel" text="Streams for:" styleClass="card-title"/>
                    <Label text="Click a subject card to assign its class streams" styleClass="card-subtitle"/>
                </HBox>
                <VBox spacing="12" styleClass="card-body">
                    <FlowPane fx:id="subjectCardContainer" hgap="16" vgap="16"/>
                </VBox>
            </VBox>

            <!-- STEP 4: Stream Toggles -->
            <VBox spacing="0" styleClass="card" fx:id="stepStreams" visible="false" managed="false">
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="card-header">
                    <Button text="&lt; Subject Cards" onAction="#onBackToStreamSubjects" styleClass="btn-back"/>
                    <Label fx:id="streamSubjectNameLabel" text="Streams for:" styleClass="card-title"/>
                </HBox>
                <VBox spacing="12" styleClass="card-body">
                    <ComboBox fx:id="formCombo" prefWidth="200" promptText="Select Form" styleClass="form-combo"/>
                    <FlowPane fx:id="streamToggleContainer" hgap="12" vgap="12"/>
                </VBox>
            </VBox>

        </VBox>
    </ScrollPane>
</VBox>
