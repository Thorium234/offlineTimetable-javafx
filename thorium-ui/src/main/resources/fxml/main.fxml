<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.thorium.ui.controller.MainController">
    <top>
        <VBox spacing="0">
            <!-- Title Bar -->
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #1e293b; -fx-padding: 8 16 8 16;">
                <Label text="Thorium" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #f8fafc;"/>
                <Label text="Timetable Generator" style="-fx-font-size: 11px; -fx-text-fill: #94a3b8; -fx-padding: 4 0 0 0;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="themeToggleBtn" onAction="#onToggleTheme" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 4 8; -fx-text-fill: #cbd5e1;"/>
            </HBox>
            <!-- Navigation Toolbar -->
            <ToolBar fx:id="navToolbar" style="-fx-background-color: #f8fafc; -fx-padding: 4 8 4 8; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;"/>
        </VBox>
    </top>
    <center>
        <StackPane fx:id="contentPane" styleClass="content-pane"/>
    </center>
    <bottom>
        <HBox styleClass="status-bar" alignment="CENTER_LEFT">
            <padding><Insets top="6" right="16" bottom="6" left="16"/></padding>
            <Label fx:id="statusLabel" text="Ready" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="generateBtn" text="Generate Timetable" onAction="#onGenerate" style="-fx-background-color: #16a34a; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 6 16 6 16; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(22,163,74,0.3), 4, 0, 0, 1);"/>
        </HBox>
    </bottom>
</BorderPane>
