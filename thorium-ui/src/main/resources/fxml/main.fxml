<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.thorium.ui.controller.MainController">
    <top>
        <VBox spacing="0">
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #1e293b; -fx-padding: 8 16 8 16;">
                <Label text="Thorium" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #f8fafc;"/>
                <Label text="Timetable Generator" style="-fx-font-size: 11px; -fx-text-fill: #94a3b8; -fx-padding: 4 0 0 0;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="themeToggleBtn" onAction="#onToggleTheme" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 4 8; -fx-text-fill: #cbd5e1;"/>
            </HBox>
            <ToolBar fx:id="navToolbar"/>
        </VBox>
    </top>
    <center>
        <StackPane fx:id="contentPane" styleClass="content-pane"/>
    </center>
    <bottom>
        <HBox styleClass="status-bar" alignment="CENTER_LEFT">
            <padding><Insets top="6" right="16" bottom="6" left="16"/></padding>
            <Label fx:id="statusLabel" text="Ready"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="generateBtn" text="Generate Timetable" onAction="#onGenerate" styleClass="generate-btn"/>
        </HBox>
    </bottom>
</BorderPane>
