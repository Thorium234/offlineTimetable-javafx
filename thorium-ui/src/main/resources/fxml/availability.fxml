<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.thorium.ui.controller.AvailabilityManagementController" spacing="16"
      styleClass="view-root">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    
    <VBox spacing="4">
        <Label text="Teacher Availability Blocker" styleClass="page-title"/>
        <Label text="Click slots on the grid to block teachers from being scheduled." styleClass="page-subtitle"/>
    </VBox>
    
    <HBox spacing="16" alignment="CENTER_LEFT" styleClass="card" style="-fx-padding: 12;">
        <Label text="Select Teacher:" styleClass="form-group-title"/>
        <ComboBox fx:id="teacherCombo" prefWidth="250" styleClass="form-combo"/>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox fx:id="quickActionsBox" spacing="8" alignment="CENTER_LEFT" disable="true">
            <Button text="Block Mornings" onAction="#onBlockMornings" styleClass="quick-action-danger"/>
            <Button text="Block Evenings" onAction="#onBlockEvenings" styleClass="quick-action-danger"/>
            <Button text="Clear All Blocks" onAction="#onClearAllBlocks" styleClass="quick-action-default"/>
        </HBox>
    </HBox>
    
    <VBox VBox.vgrow="ALWAYS" styleClass="viewer-grid-panel">
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 12 0;">
            <Label fx:id="gridTitleLabel" text="Availability Grid (Please select a teacher)" styleClass="card-title" style="-fx-font-size: 16px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="messageLabel" style="-fx-font-weight: bold;"/>
        </HBox>
        <ScrollPane fitToWidth="true" fitToHeight="true" VBox.vgrow="ALWAYS" styleClass="view-scroll">
            <GridPane fx:id="availabilityGrid" alignment="TOP_LEFT" hgap="8" vgap="8" style="-fx-background-color: transparent;"/>
        </ScrollPane>
    </VBox>
</VBox>
