<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.thorium.ui.controller.TeacherSubjectController" spacing="0"
      styleClass="view-root">
    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="page-header">
        <Label text="Teacher Subjects" styleClass="page-title"/>
        <Label text="Step 1: Link teachers to the subjects they teach" styleClass="page-subtitle"/>
    </HBox>
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="view-scroll">
        <VBox spacing="16" styleClass="view-content">
            <!-- Teacher Selector -->
            <VBox spacing="0" styleClass="card">
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="card-header">
                    <Label text="Select Teacher" styleClass="card-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="messageLabel" styleClass="msg-label"/>
                </HBox>
                <VBox spacing="12" styleClass="card-body">
                    <ComboBox fx:id="teacherCombo" prefWidth="350" styleClass="form-combo"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Button fx:id="saveBtn" text="Save Selections" onAction="#onSave" styleClass="btn-primary"/>
                    </HBox>
                </VBox>
            </VBox>

            <!-- Subject Assignment Grid -->
            <VBox spacing="0" styleClass="card">
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="card-header">
                    <Label text="Assigned Subjects" styleClass="card-title"/>
                    <Label text="Check the subjects this teacher can teach" styleClass="card-subtitle"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>
                <VBox spacing="0" styleClass="card-body" VBox.vgrow="ALWAYS">
                    <FlowPane fx:id="subjectCheckboxPane" hgap="12" vgap="10" styleClass="subject-flow-pane"/>
                    <Label fx:id="noTeacherLabel" text="Select a teacher above to manage their subjects" styleClass="empty-state"/>
                </VBox>
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>
