<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.thorium.ui.controller.TimetableViewerController"
            styleClass="editor-container">
    <top>
        <HBox spacing="16" alignment="CENTER_LEFT" styleClass="viewer-top-bar">
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label text="Interactive Timetable Workspace" styleClass="card-title" style="-fx-font-size: 18px;"/>
                <Label fx:id="filterStatusLabel" text="Select a class, teacher, or room from the sidebar to start scheduling" styleClass="page-subtitle"/>
            </VBox>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Timetable:" styleClass="form-group-title"/>
                <ComboBox fx:id="timetableCombo" prefWidth="250" styleClass="form-combo"/>
                <Button fx:id="refreshBtn" text="Refresh Workspace" onAction="#onRefresh" styleClass="btn-primary" style="-fx-background-radius: 6; -fx-padding: 6 12 6 12;"/>
                <Button fx:id="printBtn" text="Print" onAction="#onPrint" styleClass="btn-secondary" style="-fx-background-radius: 6; -fx-padding: 6 12 6 12;"/>
            </HBox>
        </HBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.20, 0.80" style="-fx-background-color: transparent; -fx-padding: 10;">
            <items>
                <VBox spacing="10" styleClass="viewer-panel">
                    <Label text="RESOURCE EXPLORER" styleClass="viewer-panel-title"/>
                    <TreeView fx:id="entityTreeView" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-width: 0;"/>
                </VBox>
                <VBox spacing="12" styleClass="viewer-grid-panel">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label fx:id="gridTitleLabel" text="Weekly Timetable Grid" styleClass="card-title" style="-fx-font-size: 16px;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="conflictWarningLabel" text="" style="-fx-text-fill: #ef4444; -fx-font-weight: 500;"/>
                    </HBox>
                    <ScrollPane fitToWidth="true" fitToHeight="true" VBox.vgrow="ALWAYS" styleClass="view-scroll">
                        <GridPane fx:id="timetableGrid" alignment="TOP_LEFT" hgap="0" vgap="0" style="-fx-background-color: transparent;"/>
                    </ScrollPane>
                </VBox>
                <VBox fx:id="poolContainer" spacing="10" styleClass="viewer-panel">
                    <Label text="UNPLACED LESSON CARDS" styleClass="viewer-panel-title"/>
                    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="view-scroll">
                        <FlowPane fx:id="unassignedPool" hgap="8" vgap="8" style="-fx-background-color: transparent;"/>
                    </ScrollPane>
                </VBox>
            </items>
        </SplitPane>
    </center>
</BorderPane>
