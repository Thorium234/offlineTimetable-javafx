<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.thorium.ui.controller.TeacherManagementController" spacing="0"
      styleClass="view-root">
    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="page-header">
        <Label text="Teachers" styleClass="page-title"/>
        <Label text="Manage teachers and their lesson contracts" styleClass="page-subtitle"/>
    </HBox>
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="view-scroll">
        <VBox spacing="16" styleClass="view-content">
            <TextField fx:id="searchField" promptText="Search teachers by name or code..." styleClass="search-field"/>
            <VBox spacing="0" styleClass="card">
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="card-header">
                    <Label text="All Teachers" styleClass="card-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>
                <TableView fx:id="teacherTable" VBox.vgrow="ALWAYS" prefHeight="200" styleClass="table-rounded">
                    <columns>
                        <TableColumn fx:id="codeColumn" text="Code" prefWidth="100"/>
                        <TableColumn fx:id="nameColumn" text="Name" prefWidth="250"/>
                    </columns>
                </TableView>
            </VBox>
            <VBox spacing="0" styleClass="card">
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="card-header">
                    <Label text="Teacher Details" styleClass="card-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="messageLabel" styleClass="msg-label"/>
                </HBox>
                <GridPane hgap="12" vgap="10" styleClass="card-body">
                    <Label text="Code" styleClass="form-group-title" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="codeField" promptText="e.g. T001" styleClass="form-textfield" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="250"/>
                    <Label text="Name" styleClass="form-group-title" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="nameField" promptText="e.g. John Doe" styleClass="form-textfield" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="250"/>
                    <CheckBox fx:id="activeCheck" text="Active" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                </GridPane>
                <HBox spacing="8" styleClass="card-body" style="-fx-padding: 0 16 16 16;">
                    <Button fx:id="saveBtn" text="Save" onAction="#onSave" defaultButton="true" styleClass="btn-primary"/>
                    <Button fx:id="deleteBtn" text="Delete" onAction="#onDelete" styleClass="btn-danger"/>
                    <Button fx:id="clearBtn" text="Clear" onAction="#onClear" styleClass="btn-secondary"/>
                </HBox>
            </VBox>
            <VBox spacing="0" styleClass="card">
                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="card-header">
                    <Label text="Teaching Contracts (Lessons)" styleClass="card-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="newLessonBtn" text="+ New Lesson" onAction="#onNewLesson" styleClass="btn-success"/>
                </HBox>
                <TableView fx:id="lessonTable" prefHeight="140" styleClass="table-rounded">
                    <columns>
                        <TableColumn fx:id="lessonSubjectColumn" text="Subject" prefWidth="180"/>
                        <TableColumn fx:id="lessonClassColumn" text="Class" prefWidth="180"/>
                        <TableColumn fx:id="lessonCountColumn" text="Lessons/Week" prefWidth="100"/>
                        <TableColumn fx:id="lessonDurationColumn" text="Duration" prefWidth="80"/>
                        <TableColumn fx:id="lessonDeleteColumn" text="" prefWidth="50"/>
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>
