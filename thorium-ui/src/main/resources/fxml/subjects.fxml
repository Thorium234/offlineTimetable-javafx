<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.thorium.ui.controller.SubjectManagementController" spacing="0"
      styleClass="view-root">
    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="page-header">
        <Label text="Subjects" styleClass="page-title"/>
        <Label text="Manage school subjects with colors and lesson defaults" styleClass="page-subtitle"/>
    </HBox>
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="view-scroll">
        <VBox spacing="16" styleClass="view-content">
            <TextField fx:id="searchField" promptText="Search subjects by name or code..." styleClass="search-field"/>
            <VBox spacing="0" styleClass="card">
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="card-header">
                    <Label text="All Subjects" styleClass="card-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>
                <TableView fx:id="subjectTable" VBox.vgrow="ALWAYS" prefHeight="200" styleClass="table-rounded">
                    <columns>
                        <TableColumn fx:id="codeColumn" text="Code" prefWidth="100"/>
                        <TableColumn fx:id="nameColumn" text="Name" prefWidth="200"/>
                        <TableColumn fx:id="examinableColumn" text="Examinable" prefWidth="80"/>
                    </columns>
                </TableView>
            </VBox>
            <VBox spacing="0" styleClass="card">
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="card-header">
                    <Label text="Subject Details" styleClass="card-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="messageLabel" styleClass="msg-label"/>
                </HBox>
                <GridPane hgap="12" vgap="10" styleClass="card-body">
                    <Label text="Code" styleClass="form-group-title" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="codeField" promptText="e.g. MATH" styleClass="form-textfield" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="250"/>
                    <Label text="Name" styleClass="form-group-title" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="nameField" promptText="e.g. Mathematics" styleClass="form-textfield" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="250"/>
                    <CheckBox fx:id="examinableCheck" text="Examinable (CBC)" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    <Label text="Default Lessons" styleClass="form-group-title" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <Spinner fx:id="cbcLessonsSpinner" prefWidth="120" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                    <CheckBox fx:id="doublePeriodCheck" text="Allows Double Period" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                    <CheckBox fx:id="requiresDoubleCheck" text="Requires Double Period" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                    <Label text="Color" styleClass="form-group-title" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                    <ColorPicker fx:id="colorPicker" GridPane.columnIndex="1" GridPane.rowIndex="6" styleClass="color-picker"/>
                </GridPane>
                <HBox spacing="8" styleClass="card-body" style="-fx-padding: 0 16 16 16;">
                    <Button fx:id="saveBtn" text="Save" onAction="#onSave" defaultButton="true" styleClass="btn-primary"/>
                    <Button fx:id="deleteBtn" text="Delete" onAction="#onDelete" styleClass="btn-danger"/>
                    <Button fx:id="clearBtn" text="Clear" onAction="#onClear" styleClass="btn-secondary"/>
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>
