<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.thorium.ui.controller.ExportCenterController"
           style="-fx-background-color: #ffffff;">

    <VBox spacing="20" maxWidth="620" alignment="TOP_CENTER">
        <padding>
            <Insets top="40" right="32" bottom="32" left="32"/>
        </padding>

        <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;"
               text="Export Timetable"/>

        <Label style="-fx-font-size: 12px; -fx-text-fill: #666666;"
               text="Preview and export timetable PDFs for printing."/>

        <Separator/>

        <!-- Teacher -->
        <VBox spacing="8">
            <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333333;"
                   text="Teacher Timetable"/>
            <ComboBox fx:id="teacherCombo" maxWidth="400" promptText="Choose a teacher..."/>
            <HBox spacing="10" alignment="CENTER">
                <Button fx:id="previewTeacherBtn" text="Preview"
                        style="-fx-background-color: #6b7280; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-font-size: 13px; -fx-background-radius: 6;"/>
                <Button fx:id="exportTeacherPdfBtn" text="Export PDF"
                        style="-fx-background-color: #16a34a; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 24; -fx-font-size: 13px; -fx-background-radius: 6;"/>
            </HBox>
            <Label fx:id="teacherStatusLabel" style="-fx-font-size: 11px; -fx-text-fill: #888888;"/>
        </VBox>

        <Separator/>

        <!-- Class -->
        <VBox spacing="8">
            <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333333;"
                   text="Class / Stream Timetable"/>
            <ComboBox fx:id="classCombo" maxWidth="400" promptText="Choose a class..."/>
            <HBox spacing="10" alignment="CENTER">
                <Button fx:id="previewClassBtn" text="Preview"
                        style="-fx-background-color: #6b7280; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-font-size: 13px; -fx-background-radius: 6;"/>
                <Button fx:id="exportClassPdfBtn" text="Export PDF"
                        style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 24; -fx-font-size: 13px; -fx-background-radius: 6;"/>
            </HBox>
            <Label fx:id="classStatusLabel" style="-fx-font-size: 11px; -fx-text-fill: #888888;"/>
        </VBox>

        <Separator/>

        <!-- School-wide -->
        <VBox spacing="8">
            <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333333;"
                   text="School Timetable (All Classes)"/>
            <Label style="-fx-font-size: 11px; -fx-text-fill: #888888;"
                   text="Combined PDF with one page per class/stream."/>
            <HBox spacing="10" alignment="CENTER">
                <Button fx:id="previewAllClassesBtn" text="Preview"
                        style="-fx-background-color: #6b7280; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-font-size: 13px; -fx-background-radius: 6;"/>
                <Button fx:id="exportAllClassesPdfBtn" text="Export PDF"
                        style="-fx-background-color: #dc2626; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 24; -fx-font-size: 13px; -fx-background-radius: 6;"/>
            </HBox>
            <Label fx:id="allClassesStatusLabel" style="-fx-font-size: 11px; -fx-text-fill: #888888;"/>
        </VBox>
    </VBox>
</StackPane>
