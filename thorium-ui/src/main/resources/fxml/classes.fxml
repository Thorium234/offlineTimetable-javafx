<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.thorium.ui.controller.ClassManagementController" spacing="0"
      styleClass="view-root">
    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="page-header">
        <Label text="Classes" styleClass="page-title"/>
        <Label text="Manage class streams and grade groups" styleClass="page-subtitle"/>
    </HBox>
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="view-scroll">
        <VBox spacing="16" styleClass="view-content">
            <TextField fx:id="searchField" promptText="Search classes by name, code, or stream..." styleClass="search-field"/>
            <VBox spacing="0" styleClass="card">
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="card-header">
                    <Label text="All Classes" styleClass="card-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>
                <TableView fx:id="classTable" VBox.vgrow="ALWAYS" prefHeight="200" styleClass="table-rounded">
                    <columns>
                        <TableColumn fx:id="codeColumn" text="Code" prefWidth="100"/>
                        <TableColumn fx:id="formColumn" text="Form" prefWidth="60"/>
                        <TableColumn fx:id="streamColumn" text="Stream" prefWidth="100"/>
                        <TableColumn fx:id="displayColumn" text="Display Name" prefWidth="200"/>
                    </columns>
                </TableView>
            </VBox>
            <VBox spacing="0" styleClass="card">
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="card-header">
                    <Label text="Class Details" styleClass="card-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="messageLabel" styleClass="msg-label"/>
                </HBox>
                <GridPane hgap="12" vgap="10" styleClass="card-body">
                    <Label text="Code" styleClass="form-group-title" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="codeField" promptText="e.g. F1E" styleClass="form-textfield" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="250"/>
                    <Label text="Form" styleClass="form-group-title" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Spinner fx:id="formSpinner" prefWidth="120" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <Label text="Stream" styleClass="form-group-title" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <TextField fx:id="streamField" promptText="e.g. East" styleClass="form-textfield" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="250"/>
                    <Label text="Display Name" styleClass="form-group-title" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <TextField fx:id="displayField" promptText="e.g. Form 1 East" styleClass="form-textfield" GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="250"/>
                </GridPane>
                <HBox spacing="8" styleClass="card-body" style="-fx-padding: 0 16 16 16;">
                    <Button fx:id="saveBtn" text="Save" onAction="#onSave" defaultButton="true" styleClass="btn-primary"/>
                    <Button fx:id="deleteBtn" text="Delete" onAction="#onDelete" styleClass="btn-danger"/>
                    <Button fx:id="clearBtn" text="Clear" onAction="#onClear" styleClass="btn-secondary"/>
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>
